# truss server base URL (as seen by the browser)
TRUSS_PUBLIC_BASE_URL=http://localhost:8080

# Signing credentials (must match TRUSS_SIGNING_KEYS on the truss server)
TRUSS_KEY_ID=dev-key
TRUSS_KEY_SECRET=dev-secret-change-in-production

# Signed URL lifetime in seconds (default: 3600)
TRUSS_URL_TTL_SECONDS=3600
